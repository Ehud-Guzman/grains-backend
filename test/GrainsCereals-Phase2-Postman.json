    {
      "name": "04 - Customer Orders",
      "item": [
        {
          "name": "Place Customer Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Order ref generated', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.data.orderRef).to.match(/^ORD-\\d{4}-\\d{4}$/);",
                  "  pm.collectionVariables.set('orderId', json.data.orderId);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{customerToken}}"
              }
            ],
            "url": "{{baseUrl}}/api/orders",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"deliveryMethod\": \"delivery\",\n  \"deliveryAddress\": \"123 Moi Avenue, Nairobi\",\n  \"paymentMethod\": \"pickup\",\n  \"specialInstructions\": \"Call before delivery\",\n  \"orderItems\": [\n    {\n      \"productId\": \"{{productId}}\",\n      \"variety\": \"Yellow Maize\",\n      \"packaging\": \"50kg\",\n      \"quantity\": 2\n    }\n  ]\n}"
            }
          }
        },
        {
          "name": "Place Order - Bulk Item (expect 409)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 409', () => pm.response.to.have.status(409));",
                  "pm.test('Bulk rejected', () => {",
                  "  pm.expect(pm.response.json().success).to.be.false;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{customerToken}}"
              }
            ],
            "url": "{{baseUrl}}/api/orders",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"deliveryMethod\": \"pickup\",\n  \"paymentMethod\": \"pickup\",\n  \"orderItems\": [\n    {\n      \"productId\": \"{{productId}}\",\n      \"variety\": \"Yellow Maize\",\n      \"packaging\": \"Bulk\",\n      \"quantity\": 1\n    }\n  ]\n}"
            }
          }
        },
