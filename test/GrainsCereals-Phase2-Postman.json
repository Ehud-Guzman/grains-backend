{
  "info": {
    "name": "Grains & Cereals API - Phase 2",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "adminToken",
      "value": ""
    },
    {
      "key": "customerToken",
      "value": ""
    },
    {
      "key": "productId",
      "value": ""
    },
    {
      "key": "orderId",
      "value": ""
    },
    {
      "key": "guestOrderRef",
      "value": ""
    },
    {
      "key": "newOrderId",
      "value": ""
