          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": "{{baseUrl}}/api/admin/products/{{productId}}"
          }
        },
        {
          "name": "Update Product",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Description updated', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.data.description).to.include('Updated');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": "{{baseUrl}}/api/admin/products/{{productId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Updated - Premium quality maize, locally sourced from Rift Valley\"\n}"
            }
          }
        },
        {
          "name": "Toggle Product Inactive",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('isActive toggled', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.data.isActive).to.be.false;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": "{{baseUrl}}/api/admin/products/{{productId}}/toggle-active"
          }
        },
        {
          "name": "Toggle Product Back Active",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('isActive true again', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.data.isActive).to.be.true;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": "{{baseUrl}}/api/admin/products/{{productId}}/toggle-active"
          }
        },
        {
          "name": "Duplicate Product",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Copy is inactive draft', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.data.name).to.include('Copy');",
                  "  pm.expect(json.data.isActive).to.be.false;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": "{{baseUrl}}/api/admin/products/{{productId}}/duplicate"
          }
        },
        {
          "name": "Admin Access Without Token (expect 401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));",
                  "pm.test('NO_TOKEN error', () => {",
                  "  pm.expect(pm.response.json().error).to.equal('NO_TOKEN');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/admin/products"
          }
        },
        {
          "name": "Admin Access With Customer Token (expect 403)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 403', () => pm.response.to.have.status(403));",
                  "pm.test('FORBIDDEN error', () => {",
                  "  pm.expect(pm.response.json().error).to.equal('FORBIDDEN');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{customerToken}}"
              }
            ],
            "url": "{{baseUrl}}/api/admin/products"
          }
        }
      ]
