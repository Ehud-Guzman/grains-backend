  "item": [
    {
      "name": "01 - Auth Setup",
      "item": [
        {
          "name": "Register Admin User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Has tokens', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.success).to.be.true;",
                  "  pm.expect(json.data.accessToken).to.exist;",
                  "  pm.collectionVariables.set('customerId', json.data.user.id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin User\",\n  \"phone\": \"0700000001\",\n  \"password\": \"admin1234\"\n}"
            }
          }
        },
        {
          "name": "Login as Admin (after Atlas role change)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Token saved', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.success).to.be.true;",
                  "  pm.collectionVariables.set('adminToken', json.data.accessToken);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"0700000001\",\n  \"password\": \"admin1234\"\n}"
            }
          }
        },
        {
          "name": "Login as Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Customer token saved', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.success).to.be.true;",
                  "  pm.collectionVariables.set('customerToken', json.data.accessToken);",
                  "  pm.collectionVariables.set('customerId', json.data.user.id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"0712345678\",\n  \"password\": \"password123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "02 - Product Management (Admin)",
      "item": [
        {
          "name": "Create Product",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Product created and ID saved', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.success).to.be.true;",
                  "  pm.expect(json.data._id).to.exist;",
                  "  pm.collectionVariables.set('productId', json.data._id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": "{{baseUrl}}/api/admin/products",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Maize\",\n  \"category\": \"Cereals\",\n  \"description\": \"Premium quality maize, locally sourced\",\n  \"isActive\": true,\n  \"varieties\": [\n    {\n      \"varietyName\": \"Yellow Maize\",\n      \"description\": \"Dry yellow maize grain\",\n      \"imageURLs\": [],\n      \"packaging\": [\n        { \"size\": \"50kg\", \"priceKES\": 3800, \"stock\": 100, \"lowStockThreshold\": 10, \"quoteOnly\": false },\n        { \"size\": \"90kg\", \"priceKES\": 6500, \"stock\": 45, \"lowStockThreshold\": 5, \"quoteOnly\": false },\n        { \"size\": \"Bulk\", \"priceKES\": null, \"stock\": 0, \"lowStockThreshold\": 0, \"quoteOnly\": true }\n      ]\n    },\n    {\n      \"varietyName\": \"White Maize\",\n      \"description\": \"Premium white maize\",\n      \"imageURLs\": [],\n      \"packaging\": [\n        { \"size\": \"50kg\", \"priceKES\": 4000, \"stock\": 60, \"lowStockThreshold\": 10, \"quoteOnly\": false }\n      ]\n    }\n  ]\n}"
            }
          }
        },
        {
          "name": "Create Product - Missing Name (expect 400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "pm.test('VALIDATION_ERROR', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.error).to.equal('VALIDATION_ERROR');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": "{{baseUrl}}/api/admin/products",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"category\": \"Cereals\",\n  \"varieties\": []\n}"
            }
          }
        },
        {
          "name": "Get All Admin Products",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has products array', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.success).to.be.true;",
                  "  pm.expect(json.data).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": "{{baseUrl}}/api/admin/products"
          }
        },
        {
          "name": "Get Single Product (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Correct product returned', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.data.name).to.equal('Maize');",
                  "});"
