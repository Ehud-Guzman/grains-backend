    {
      "name": "08 - User Management (SuperAdmin only)",
      "item": [
        {
          "name": "Create Staff Account",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Staff account created', () => {",
                  "  const d = pm.response.json().data;",
                  "  pm.expect(d.role).to.equal('staff');",
                  "  pm.expect(d.id).to.exist;",
                  "  pm.collectionVariables.set('newStaffId', d.id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{superAdminToken}}" }
            ],
            "url": "{{baseUrl}}/api/admin/users",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Staff\",\n  \"phone\": \"0711000099\",\n  \"password\": \"staffpass123\",\n  \"role\": \"staff\"\n}"
            }
          }
        },
        {
          "name": "Create Staff - Invalid Role (expect 400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "pm.test('VALIDATION_ERROR', () => {",
                  "  pm.expect(pm.response.json().error).to.equal('VALIDATION_ERROR');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{superAdminToken}}" }
            ],
            "url": "{{baseUrl}}/api/admin/users",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Bad Role\",\n  \"phone\": \"0711000077\",\n  \"password\": \"pass12345\",\n  \"role\": \"superuser\"\n}"
            }
          }
        },
        {
          "name": "Create Staff - Duplicate Phone (expect 409)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 409', () => pm.response.to.have.status(409));",
                  "pm.test('PHONE_TAKEN', () => {",
                  "  pm.expect(pm.response.json().error).to.equal('PHONE_TAKEN');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{superAdminToken}}" }
            ],
            "url": "{{baseUrl}}/api/admin/users",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Duplicate\",\n  \"phone\": \"0711000099\",\n  \"password\": \"pass12345\",\n  \"role\": \"staff\"\n}"
            }
          }
        },
        {
          "name": "Get All Admin Users",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns admin users list', () => {",
                  "  pm.expect(pm.response.json().data).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{superAdminToken}}" }],
            "url": "{{baseUrl}}/api/admin/users"
          }
        },
        {
          "name": "Change Role - Staff to Supervisor",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Role updated to supervisor', () => {",
                  "  pm.expect(pm.response.json().data.role).to.equal('supervisor');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{superAdminToken}}" }
            ],
            "url": "{{baseUrl}}/api/admin/users/{{newStaffId}}/role",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"supervisor\"\n}"
            }
          }
        },
        {
          "name": "Change Role - Invalid Role (expect 400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{superAdminToken}}" }
            ],
            "url": "{{baseUrl}}/api/admin/users/{{newStaffId}}/role",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"manager\"\n}"
            }
          }
        },
        {
          "name": "Lock Account",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Account locked', () => {",
                  "  pm.expect(pm.response.json().data.isLocked).to.be.true;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{superAdminToken}}" }],
            "url": "{{baseUrl}}/api/admin/users/{{newStaffId}}/lock"
          }
        },
        {
          "name": "Unlock Account",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Account unlocked', () => {",
                  "  pm.expect(pm.response.json().data.isLocked).to.be.false;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
