{
  "info": {
    "name": "Grains & Cereals API - Phase 3 (Reports, Users, Logs)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "adminToken", "value": "" },
    { "key": "superAdminToken", "value": "" },
    { "key": "newStaffId", "value": "" }
  ],
  "item": [
    {
      "name": "01 - Auth Setup",
      "item": [
        {
          "name": "Login as Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Admin token saved', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.success).to.be.true;",
                  "  pm.collectionVariables.set('adminToken', json.data.accessToken);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"0700000001\",\n  \"password\": \"admin1234\"\n}"
            }
          }
        },
        {
          "name": "Register SuperAdmin User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 or 409 (already exists)', () => {",
                  "  pm.expect([201, 409]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Super Admin\",\n  \"phone\": \"0700000002\",\n  \"password\": \"superadmin1234\"\n}"
            }
          }
        },
        {
          "name": "Login as SuperAdmin (after Atlas role change to superadmin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('SuperAdmin token saved', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.success).to.be.true;",
                  "  pm.collectionVariables.set('superAdminToken', json.data.accessToken);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"0700000002\",\n  \"password\": \"superadmin1234\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "02 - Dashboard KPIs",
      "item": [
        {
          "name": "Get Dashboard KPIs",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has all KPI fields', () => {",
                  "  const d = pm.response.json().data;",
                  "  pm.expect(d.ordersToday).to.exist;",
                  "  pm.expect(d.pendingOrders).to.exist;",
                  "  pm.expect(d.revenueToday).to.exist;",
                  "  pm.expect(d.revenueThisMonth).to.exist;",
                  "  pm.expect(d.lowStockCount).to.exist;",
                  "  pm.expect(d.recentOrders).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/admin/reports/kpis"
          }
        },
        {
          "name": "Get KPIs - No Token (expect 401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/admin/reports/kpis"
          }
        }
      ]
    },
