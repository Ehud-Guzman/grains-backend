# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/grains-shop

# JWT
JWT_ACCESS_SECRET=<minimum-64-char-random-string>
JWT_REFRESH_SECRET=<minimum-64-char-random-string>
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# M-Pesa (Safaricom Daraja)
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_SHORTCODE=
MPESA_CALLBACK_URL=https://yourdomain.co.ke/api/payments/mpesa/callback
MPESA_ENV=sandbox

# Cloudinary (product images)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Notifications - Africa's Talking (Phase 2)
AT_API_KEY=
AT_USERNAME=

# Error Tracking
SENTRY_DSN=

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Performance logging
SLOW_REQUEST_THRESHOLD_MS=1200

# Backup storage
# Use an absolute path in production, e.g. D:\GrainsSystemData\backups
# If omitted, backups are stored outside the backend app tree in ../runtime-data/backups
BACKUP_STORAGE_DIR=
